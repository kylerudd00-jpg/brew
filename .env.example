# ── Beer Intel — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values you have.
# The app runs WITHOUT any keys — uses free Open Brewery DB + zippopotam.us.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Google APIs (optional — higher-quality brewery discovery) ─────────────────
# Enable Geocoding API + Places API in Google Cloud Console
# Free tier: $200/month credit — https://console.cloud.google.com
# GOOGLE_API_KEY=your_google_api_key_here

# ── Eventbrite (optional — brewery event listings) ────────────────────────────
# https://www.eventbrite.com/platform/api-keys
# EVENTBRITE_TOKEN=your_eventbrite_private_token_here

# ── Admin API protection ──────────────────────────────────────────────────────
# Protect /admin/* endpoints. Pass as x-admin-key header.
# ADMIN_KEY=change_me_to_a_random_secret

# ── Search defaults ───────────────────────────────────────────────────────────
SEARCH_RADIUS_MILES=15
SCRAPE_BUDGET_MS=1500

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
BREWERY_CACHE_MAX_AGE_SEC=21600
OPENBREWERY_TIMEOUT_MS=2500

# ── Rate limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=60000

# ── Background refresher ──────────────────────────────────────────────────────
# REFRESH_STALE_HOURS=6
# REFRESH_INTERVAL_MS=1800000
# REFRESH_BETWEEN_MS=3000
# REFRESH_MAX_PER_RUN=10
